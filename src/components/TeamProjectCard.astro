---
interface Props {
  title: string;
  description: string;
  tags: string[];
  github?: string | null;
  demo?: string | null;
  year?: number;
  highlight?: boolean;
  index: number;
}
const { title, description, tags, github, demo, year, highlight, index } = Astro.props;
---

<article class={`tpc ${highlight ? 'highlight' : ''}`} style={`--i:${index}`}>
  <div class="tpc-top">
    <div class="tpc-left">
      {highlight && <span class="tpc-badge">destacado</span>}
      <h3 class="tpc-title">{title}</h3>
      {year && <span class="tpc-year">{year}</span>}
    </div>
    <div class="tpc-actions">
      {(github || demo) && (
        <button
          class="tpc-btn preview-btn"
          data-preview
          data-title={title}
          data-description={description}
          data-tags={JSON.stringify(tags)}
          data-github={github || ''}
          data-demo={demo || ''}
          aria-label="Vista previa"
        >
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          preview
        </button>
      )}
      {github && (
        <a href={github} target="_blank" rel="noopener" aria-label="GitHub" class="tpc-btn">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
          repo
        </a>
      )}
      {demo && (
        <a href={demo} target="_blank" rel="noopener" aria-label="Demo" class="tpc-btn primary">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          demo
        </a>
      )}
    </div>
  </div>
  <p class="tpc-desc">{description}</p>
  <div class="tpc-tags">
    {tags.map(t => <span>{t}</span>)}
  </div>
</article>

<style>
  .tpc {
    background: var(--bg-card);
    border: 1.5px solid var(--border);
    border-radius: 10px;
    padding: 1.25rem 1.4rem;
    display: flex; flex-direction: column; gap: 0.65rem;
    transition: border-color var(--t), transform var(--t);
    animation: fadeUp 0.4s ease both;
    animation-delay: calc(var(--i) * 60ms);
  }
  .tpc:hover { border-color: #d4500a; transform: translateY(-2px); }
  .tpc.highlight { border-color: rgba(212,80,10,0.35); }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .tpc-top { display: flex; justify-content: space-between; align-items: flex-start; gap: 0.75rem; flex-wrap: wrap; }
  .tpc-left { display: flex; flex-direction: column; gap: 0.25rem; }

  .tpc-badge {
    display: inline-block;
    font-size: 0.62rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #d4500a;
    background: rgba(212,80,10,0.09);
    border: 1px solid rgba(212,80,10,0.25);
    padding: 0.12rem 0.45rem;
    border-radius: 3px;
    width: fit-content;
  }

  .tpc-title { font-family: var(--font-sans); font-size: 0.95rem; font-weight: 700; color: var(--text); letter-spacing: -0.02em; }
  .tpc-year { font-size: 0.68rem; color: var(--text-3); }

  .tpc-actions { display: flex; gap: 0.4rem; align-items: center; }

  .tpc-btn {
    display: inline-flex; align-items: center; gap: 0.3rem;
    font-size: 0.7rem; font-family: var(--font-mono);
    padding: 0.3rem 0.7rem; border-radius: 5px;
    border: 1px solid var(--border); color: var(--text-2);
    background: transparent; cursor: pointer; transition: all var(--t);
  }
  .tpc-btn:hover { border-color: var(--text-2); color: var(--text); }
  .tpc-btn.primary { background: var(--text); color: var(--bg-card); border-color: var(--text); }
  .tpc-btn.primary:hover { background: #d4500a; border-color: #d4500a; }
  .preview-btn { color: var(--accent); border-color: color-mix(in srgb, var(--accent) 35%, var(--border)); }
  .preview-btn:hover { background: var(--accent); color: #fff; border-color: var(--accent); }

  .tpc-desc { font-size: 0.78rem; color: var(--text-2); line-height: 1.65; }
  .tpc-tags { display: flex; flex-wrap: wrap; gap: 0.35rem; }
  .tpc-tags span {
    font-size: 0.65rem;
    padding: 0.15rem 0.45rem;
    border-radius: 4px;
    background: var(--bg);
    border: 1px solid var(--border);
    color: var(--text-3);
  }
</style>
