---
import Layout from '../layouts/Layout.astro';
import MemberCard from '../components/MemberCard.astro';
import TeamProjectCard from '../components/TeamProjectCard.astro';
import { teamInfo, members, teamProjects } from '../data';

const highlighted = teamProjects.filter(p => p.highlight);
const rest = teamProjects.filter(p => !p.highlight);
const allSkills = [...new Set(members.flatMap(m => m.skills))];
const availableCount = members.filter(m => m.available).length;
---

<Layout title={teamInfo.name} description={teamInfo.tagline}>

  <!-- ══════════════ NAV ══════════════ -->
  <nav>
    <a href="/" class="nav-brand">
      <span class="brand-dot"></span>
      {teamInfo.name}
    </a>
    <ul>
      <li><a href="#equipo">equipo</a></li>
      <li><a href="#proyectos">proyectos</a></li>
      <li><a href="#contacto">contacto</a></li>
    </ul>
    <div class="nav-right">
      <button class="theme-toggle" id="themeToggle" aria-label="Cambiar tema">
        <svg class="icon-sun" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <svg class="icon-moon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
        </svg>
      </button>
      <a href={`mailto:${teamInfo.email}`} class="nav-cta">hablemos</a>
    </div>
  </nav>

  <!-- ══════════════ PREVIEW MODAL ══════════════ -->
  <div id="previewModal" class="modal-backdrop" aria-hidden="true">
    <div class="modal-box" role="dialog" aria-modal="true" aria-labelledby="modalTitle">
      <div class="modal-header">
        <div class="modal-title-wrap">
          <span class="modal-eyebrow">vista previa</span>
          <h3 id="modalTitle" class="modal-title">—</h3>
        </div>
        <div class="modal-actions">
          <a id="modalGithub" href="#" target="_blank" rel="noopener" class="modal-btn">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
            repo
          </a>
          <a id="modalDemo" href="#" target="_blank" rel="noopener" class="modal-btn accent">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            abrir demo
          </a>
          <button id="modalClose" class="modal-close" aria-label="Cerrar">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </button>
        </div>
      </div>
      <div class="modal-body">
        <div id="modalIframeWrap" class="iframe-wrap">
          <div class="iframe-bar">
            <span class="bar-dot r"></span><span class="bar-dot y"></span><span class="bar-dot g"></span>
            <span id="modalUrl" class="bar-url"></span>
          </div>
          <iframe id="modalIframe" src="" title="Vista previa" loading="lazy"
            sandbox="allow-scripts allow-same-origin allow-forms allow-popups"></iframe>
        </div>
        <div id="modalInfo" class="modal-info">
          <div class="info-icon">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="currentColor" opacity="0.25"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
          </div>
          <h4 id="infoTitle" class="info-title"></h4>
          <p id="infoDesc" class="info-desc"></p>
          <div id="infoTags" class="info-tags"></div>
          <a id="infoGithubLink" href="#" target="_blank" rel="noopener" class="info-cta">Ver repositorio →</a>
        </div>
        <div id="modalLoading" class="modal-loading">
          <div class="loading-spinner"></div>
          <span>cargando preview...</span>
        </div>
      </div>
    </div>
  </div>

  <main>

    <!-- ══════════════ HERO ══════════════ -->
    <section class="hero">
      <div class="hero-inner container">
        <div class="hero-eyebrow">
          <span class="eyebrow-pill">
            <span class="eyebrow-dot"></span>
            {availableCount} {availableCount === 1 ? 'miembro disponible' : 'miembros disponibles'}
          </span>
          <span class="eyebrow-tag">Est. {teamInfo.founded} · {teamInfo.location}</span>
        </div>
        <h1 class="hero-title">
          <span class="ht-line">Somos</span>
          <span class="ht-accent">{teamInfo.name}</span>
        </h1>
        <p class="hero-desc">{teamInfo.description}</p>
        <div class="hero-stats">
          <div class="stat"><span class="stat-n">{members.length}</span><span class="stat-l">miembros</span></div>
          <div class="stat-div"></div>
          <div class="stat"><span class="stat-n">{teamProjects.length}</span><span class="stat-l">proyectos</span></div>
          <div class="stat-div"></div>
          <div class="stat"><span class="stat-n">{allSkills.length}+</span><span class="stat-l">tecnologías</span></div>
        </div>
        <div class="hero-actions">
          <a href="#equipo" class="btn-primary">conocer al equipo</a>
          <a href="#proyectos" class="btn-outline">ver proyectos</a>
        </div>
      </div>
      <div class="hero-deco" aria-hidden="true">
        {Array.from({length: 80}).map((_, i) => <span style={`animation-delay:${Math.random()*3}s`}></span>)}
      </div>
    </section>

    <!-- ══════════════ TEAM ══════════════ -->
    <section id="equipo" class="section">
      <div class="container">
        <header class="sec-header">
          <div>
            <p class="sec-label">// equipo</p>
            <h2 class="sec-title">Las personas detrás del código</h2>
          </div>
          <p class="sec-sub">Cada miembro aporta una perspectiva única. Juntos cubrimos el stack completo.</p>
        </header>
        <div class="member-nav">
          {members.map((m, i) => {
            const colors = ['#d4500a','#2563eb','#2d7a3a','#7c3aed','#b91c1c','#0369a1'];
            const c = colors[i % colors.length];
            return (
              <a href={`#member-${m.id}`} class="member-jump" style={`--jc:${c}`}>
                <span class="jump-avatar" style={`background:color-mix(in srgb, ${c} 12%, #fff); border-color: color-mix(in srgb, ${c} 20%, var(--border)); color:${c}`}>
                  {m.name.split(' ').map((n: string) => n[0]).join('').slice(0,2)}
                </span>
                <span class="jump-name">{m.name.split(' ')[0]}</span>
              </a>
            );
          })}
        </div>
        <div class="members-grid">
          {members.map((member, i) => <MemberCard {...member} index={i} />)}
        </div>
      </div>
    </section>

    <!-- ══════════════ TEAM PROJECTS ══════════════ -->
    <section id="proyectos" class="section section-stripe">
      <div class="container">
        <header class="sec-header">
          <div>
            <p class="sec-label">// proyectos del equipo</p>
            <h2 class="sec-title">Lo que hemos construido juntos</h2>
          </div>
          <p class="sec-sub">Proyectos colaborativos donde todo el equipo ha participado.</p>
        </header>
        {highlighted.length > 0 && (
          <div class="projects-block">
            <p class="block-label">destacados</p>
            <div class="projects-grid highlight-grid">
              {highlighted.map((p, i) => <TeamProjectCard {...p} index={i} />)}
            </div>
          </div>
        )}
        {rest.length > 0 && (
          <div class="projects-block">
            <p class="block-label">más proyectos</p>
            <div class="projects-grid">
              {rest.map((p, i) => <TeamProjectCard {...p} index={i + highlighted.length} />)}
            </div>
          </div>
        )}
      </div>
    </section>

    <!-- ══════════════ CONTACT ══════════════ -->
    <section id="contacto" class="section">
      <div class="container">
        <div class="contact-box">
          <div class="contact-left">
            <p class="sec-label" style="color:#f06b25">// contacto</p>
            <h2 class="contact-title">¿Tienes un proyecto en mente?</h2>
            <p class="contact-body">Trabajamos con empresas y startups en proyectos de producto, consultoría técnica y desarrollo a medida. Escríbenos y hablamos.</p>
            <div class="contact-links">
              {teamInfo.github && <a href={teamInfo.github} target="_blank" rel="noopener" class="c-link">GitHub</a>}
              {teamInfo.linkedin && <a href={teamInfo.linkedin} target="_blank" rel="noopener" class="c-link">LinkedIn</a>}
              {teamInfo.website && <a href={teamInfo.website} target="_blank" rel="noopener" class="c-link">Website</a>}
            </div>
          </div>
          <div class="contact-right">
            <a href={`mailto:${teamInfo.email}`} class="email-btn">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              {teamInfo.email}
            </a>
            <p class="reply-note">Respondemos en menos de 24 horas.</p>
          </div>
        </div>
      </div>
    </section>

    <footer>
      <div class="container footer-inner">
        <span class="footer-l">{teamInfo.name} · {new Date().getFullYear()} · {teamInfo.location}</span>
        <span class="footer-r">construido con Astro</span>
      </div>
    </footer>

  </main>
</Layout>

<style>
  /* ── Nav ── */
  nav {
    position: sticky; top: 0; z-index: 200;
    display: flex; align-items: center; gap: 2rem;
    padding: 0.9rem 2rem;
    background: color-mix(in srgb, var(--bg) 90%, transparent);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    transition: background 0.25s ease;
  }
  .nav-brand { display: flex; align-items: center; gap: 0.5rem; font-family: var(--font-sans); font-size: 0.95rem; font-weight: 800; letter-spacing: -0.03em; margin-right: auto; }
  .brand-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--accent); flex-shrink: 0; }
  nav ul { display: flex; list-style: none; gap: 1.5rem; }
  nav ul a { font-size: 0.78rem; color: var(--text-2); letter-spacing: 0.03em; transition: color var(--t); position: relative; }
  nav ul a::after { content:''; position:absolute; bottom:-2px; left:0; width:0; height:1px; background:var(--accent); transition:width var(--t); }
  nav ul a:hover { color: var(--text); }
  nav ul a:hover::after { width: 100%; }
  .nav-right { display: flex; align-items: center; gap: 0.6rem; }

  /* Theme toggle */
  .theme-toggle {
    display: flex; align-items: center; justify-content: center;
    width: 32px; height: 32px; border-radius: 7px;
    border: 1px solid var(--border); background: var(--bg-card);
    color: var(--text-2); cursor: pointer; transition: all var(--t);
  }
  .theme-toggle:hover { border-color: var(--accent); color: var(--accent); }
  .icon-sun { display: none; }
  .icon-moon { display: block; }
  :global(html.dark) .icon-sun { display: block; }
  :global(html.dark) .icon-moon { display: none; }

  .nav-cta { font-size: 0.75rem; font-family: var(--font-mono); padding: 0.4rem 1rem; background: var(--text); color: var(--bg); border-radius: 6px; transition: background var(--t); }
  .nav-cta:hover { background: var(--accent); }

  /* ── Modal ── */
  .modal-backdrop {
    position: fixed; inset: 0; z-index: 999;
    background: rgba(0,0,0,0.65); backdrop-filter: blur(5px);
    display: flex; align-items: center; justify-content: center; padding: 1.5rem;
    opacity: 0; pointer-events: none; transition: opacity 0.2s ease;
  }
  .modal-backdrop.open { opacity: 1; pointer-events: all; }

  .modal-box {
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: 14px; width: 100%; max-width: 920px; max-height: 88vh;
    display: flex; flex-direction: column; overflow: hidden;
    transform: translateY(14px) scale(0.98); transition: transform 0.25s ease;
    box-shadow: 0 32px 72px rgba(0,0,0,0.3);
  }
  .modal-backdrop.open .modal-box { transform: translateY(0) scale(1); }

  .modal-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 1rem 1.25rem; border-bottom: 1px solid var(--border);
    gap: 1rem; flex-wrap: wrap; flex-shrink: 0;
  }
  .modal-eyebrow { font-size: 0.62rem; color: var(--accent); letter-spacing: 0.1em; text-transform: uppercase; display: block; margin-bottom: 0.15rem; }
  .modal-title { font-family: var(--font-sans); font-size: 0.95rem; font-weight: 700; letter-spacing: -0.02em; }
  .modal-actions { display: flex; gap: 0.4rem; align-items: center; }

  .modal-btn {
    display: inline-flex; align-items: center; gap: 0.35rem;
    font-size: 0.7rem; font-family: var(--font-mono);
    padding: 0.3rem 0.75rem; border-radius: 5px;
    border: 1px solid var(--border); color: var(--text-2); transition: all var(--t);
  }
  .modal-btn:hover { border-color: var(--text); color: var(--text); }
  .modal-btn.accent { background: var(--accent); border-color: var(--accent); color: #fff; }
  .modal-btn.accent:hover { background: var(--accent-2); border-color: var(--accent-2); }

  .modal-close {
    display: flex; align-items: center; justify-content: center;
    width: 30px; height: 30px; border-radius: 6px;
    border: 1px solid var(--border); background: transparent;
    color: var(--text-2); cursor: pointer; transition: all var(--t);
  }
  .modal-close:hover { border-color: var(--text); color: var(--text); background: var(--bg); }

  .modal-body { flex: 1; overflow: hidden; position: relative; min-height: 420px; }

  /* iframe mode */
  .iframe-wrap { height: 100%; display: flex; flex-direction: column; }
  .iframe-bar { display: flex; align-items: center; gap: 0.5rem; padding: 0.5rem 0.85rem; background: var(--bg); border-bottom: 1px solid var(--border); flex-shrink: 0; }
  .bar-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
  .bar-dot.r { background: #ff5f57; }
  .bar-dot.y { background: #febc2e; }
  .bar-dot.g { background: #28c840; }
  .bar-url { flex: 1; font-size: 0.68rem; color: var(--text-3); font-family: var(--font-mono); background: var(--bg-card); border: 1px solid var(--border); padding: 0.2rem 0.6rem; border-radius: 4px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  #modalIframe { flex: 1; width: 100%; border: none; background: #fff; }

  /* info-only mode (no demo URL) */
  .modal-info {
    height: 100%; display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: 0.85rem; padding: 3rem 2rem; text-align: center;
  }
  .info-title { font-family: var(--font-sans); font-size: 1.3rem; font-weight: 700; letter-spacing: -0.03em; }
  .info-desc { font-size: 0.82rem; color: var(--text-2); line-height: 1.7; max-width: 480px; }
  .info-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; justify-content: center; }
  .info-tags span { font-size: 0.68rem; padding: 0.2rem 0.55rem; border-radius: 4px; background: var(--bg); border: 1px solid var(--border); color: var(--text-3); }
  .info-cta { margin-top: 0.5rem; display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.55rem 1.2rem; background: var(--text); color: var(--bg); border-radius: 6px; font-size: 0.78rem; font-family: var(--font-mono); transition: background var(--t); }
  .info-cta:hover { background: var(--accent); }

  /* loading */
  .modal-loading { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0.75rem; font-size: 0.75rem; color: var(--text-3); background: var(--bg-card); }
  .loading-spinner { width: 24px; height: 24px; border-radius: 50%; border: 2px solid var(--border); border-top-color: var(--accent); animation: spin 0.7s linear infinite; }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* ── Container & layout ── */
  .container { max-width: 1040px; margin: 0 auto; padding: 0 2rem; }

  .hero { min-height: 88vh; display: flex; align-items: center; position: relative; overflow: hidden; border-bottom: 1px solid var(--border); }
  .hero-inner { position: relative; z-index: 2; padding-top: 4rem; padding-bottom: 4rem; }
  .hero-eyebrow { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1.5rem; flex-wrap: wrap; }
  .eyebrow-pill { display: inline-flex; align-items: center; gap: 0.4rem; font-size: 0.72rem; padding: 0.3rem 0.75rem; border-radius: 100px; background: var(--green-bg); color: var(--green); border: 1px solid color-mix(in srgb, var(--green) 30%, transparent); }
  .eyebrow-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--green); animation: blink 2s ease infinite; }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }
  .eyebrow-tag { font-size: 0.72rem; color: var(--text-3); }
  .hero-title { font-family: var(--font-sans); font-weight: 800; line-height: 1; letter-spacing: -0.05em; margin-bottom: 1.25rem; }
  .ht-line { display: block; font-size: clamp(3rem, 8vw, 6.5rem); color: var(--text); }
  .ht-accent { display: block; font-size: clamp(3rem, 8vw, 6.5rem); color: var(--accent); -webkit-text-stroke: 2px var(--accent); }
  .hero-desc { max-width: 520px; font-size: 0.88rem; color: var(--text-2); line-height: 1.8; margin-bottom: 2rem; }
  .hero-stats { display: flex; align-items: center; gap: 1.5rem; margin-bottom: 2rem; flex-wrap: wrap; }
  .stat { display: flex; flex-direction: column; gap: 0.1rem; }
  .stat-n { font-family: var(--font-sans); font-size: 1.8rem; font-weight: 800; letter-spacing: -0.04em; color: var(--text); line-height: 1; }
  .stat-l { font-size: 0.68rem; color: var(--text-3); text-transform: uppercase; letter-spacing: 0.06em; }
  .stat-div { width: 1px; height: 2rem; background: var(--border); }
  .hero-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .btn-primary { display: inline-flex; align-items: center; padding: 0.65rem 1.4rem; background: var(--text); color: var(--bg); border-radius: 7px; font-size: 0.8rem; font-family: var(--font-mono); transition: background var(--t), transform var(--t); }
  .btn-primary:hover { background: var(--accent); transform: translateY(-1px); }
  .btn-outline { display: inline-flex; align-items: center; padding: 0.65rem 1.4rem; border: 1.5px solid var(--border); color: var(--text-2); border-radius: 7px; font-size: 0.8rem; font-family: var(--font-mono); transition: all var(--t); }
  .btn-outline:hover { border-color: var(--text-2); color: var(--text); }
  .hero-deco { position: absolute; inset: 0; z-index: 1; display: grid; grid-template-columns: repeat(10, 1fr); grid-template-rows: repeat(8, 1fr); pointer-events: none; }
  .hero-deco span { border-right: 1px solid var(--border); border-bottom: 1px solid var(--border); animation: gridFade 4s ease infinite; opacity: 0; }
  @keyframes gridFade { 0%,100%{opacity:0} 50%{opacity:0.4} }

  .section { padding: 5rem 0; border-top: 1px solid var(--border); }
  .section-stripe { background: var(--bg-card); }
  .sec-header { display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 1rem; margin-bottom: 2rem; }
  .sec-label { font-size: 0.68rem; color: var(--accent); letter-spacing: 0.1em; margin-bottom: 0.35rem; }
  .sec-title { font-family: var(--font-sans); font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 800; letter-spacing: -0.04em; }
  .sec-sub { max-width: 320px; font-size: 0.78rem; color: var(--text-2); line-height: 1.65; text-align: right; }

  .member-nav { display: flex; gap: 0.6rem; flex-wrap: wrap; margin-bottom: 1.75rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--border); }
  .member-jump { display: flex; align-items: center; gap: 0.4rem; padding: 0.3rem 0.7rem 0.3rem 0.35rem; border-radius: 100px; border: 1px solid var(--border); transition: all var(--t); font-size: 0.72rem; color: var(--text-2); }
  .member-jump:hover { border-color: var(--jc); color: var(--text); background: color-mix(in srgb, var(--jc) 6%, transparent); }
  .jump-avatar { width: 22px; height: 22px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.6rem; font-weight: 700; border: 1px solid; font-family: var(--font-sans); flex-shrink: 0; }
  .members-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1rem; }
  .projects-block { margin-bottom: 2.5rem; }
  .block-label { font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-3); margin-bottom: 0.9rem; }
  .projects-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 0.85rem; }
  .highlight-grid { grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); }

  /* Contact - always dark */
  .contact-box { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center; background: #111110; border-radius: 14px; padding: 3rem; }
  .contact-title { font-family: var(--font-sans); font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; letter-spacing: -0.04em; color: #f0ede6; margin: 0.5rem 0 0.85rem; }
  .contact-body { font-size: 0.82rem; color: #8a8880; line-height: 1.8; margin-bottom: 1.25rem; }
  .contact-links { display: flex; gap: 1rem; flex-wrap: wrap; }
  .c-link { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.07em; color: #6b6965; transition: color var(--t); position: relative; }
  .c-link::after { content:''; position:absolute; bottom:-1px; left:0; width:0; height:1px; background:#f06b25; transition:width var(--t); }
  .c-link:hover { color: #f06b25; }
  .c-link:hover::after { width: 100%; }
  .contact-right { display: flex; flex-direction: column; gap: 0.75rem; align-items: flex-start; }
  .email-btn { display: inline-flex; align-items: center; gap: 0.6rem; padding: 0.9rem 1.6rem; background: var(--accent); color: #fff; border-radius: 8px; font-family: var(--font-mono); font-size: 0.82rem; transition: background var(--t), transform var(--t); }
  .email-btn:hover { background: var(--accent-2); transform: translateY(-1px); }
  .reply-note { font-size: 0.7rem; color: #5a5855; }

  footer { border-top: 1px solid var(--border); padding: 1.5rem 0; }
  .footer-inner { display: flex; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem; }
  .footer-l, .footer-r { font-size: 0.7rem; color: var(--text-3); letter-spacing: 0.04em; }

  @media (max-width: 768px) {
    nav ul { display: none; }
    .sec-header { flex-direction: column; align-items: flex-start; }
    .sec-sub { text-align: left; max-width: none; }
    .contact-box { grid-template-columns: 1fr; padding: 2rem; gap: 2rem; }
    .members-grid { grid-template-columns: 1fr; }
    .highlight-grid { grid-template-columns: 1fr; }
    .modal-box { max-height: 95vh; }
  }
</style>

<script>
  // ── Dark mode toggle ──────────────────────────────────
  const toggle = document.getElementById('themeToggle');
  toggle?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });

  // ── Scroll reveal ─────────────────────────────────────
  const io = new IntersectionObserver(
    entries => entries.forEach(e => {
      if (e.isIntersecting) {
        (e.target as HTMLElement).style.opacity = '1';
        (e.target as HTMLElement).style.transform = 'translateY(0)';
      }
    }),
    { threshold: 0.08, rootMargin: '0px 0px -30px 0px' }
  );
  document.querySelectorAll('.member-card').forEach((el, i) => {
    const h = el as HTMLElement;
    h.style.opacity = '0';
    h.style.transform = 'translateY(14px)';
    h.style.transition = `opacity 0.4s ease ${i * 60}ms, transform 0.4s ease ${i * 60}ms`;
    io.observe(el);
  });

  // ── Preview modal ─────────────────────────────────────
  const modal       = document.getElementById('previewModal')!;
  const modalTitle  = document.getElementById('modalTitle')!;
  const modalGithub = document.getElementById('modalGithub') as HTMLAnchorElement;
  const modalDemo   = document.getElementById('modalDemo') as HTMLAnchorElement;
  const modalClose  = document.getElementById('modalClose')!;
  const iframeWrap  = document.getElementById('modalIframeWrap')!;
  const iframe      = document.getElementById('modalIframe') as HTMLIFrameElement;
  const modalUrl    = document.getElementById('modalUrl')!;
  const modalInfo   = document.getElementById('modalInfo')!;
  const modalLoad   = document.getElementById('modalLoading')!;
  const infoTitle   = document.getElementById('infoTitle')!;
  const infoDesc    = document.getElementById('infoDesc')!;
  const infoTags    = document.getElementById('infoTags')!;
  const infoLink    = document.getElementById('infoGithubLink') as HTMLAnchorElement;

  // Hide all modal body states
  function resetBody() {
    iframeWrap.style.display = 'none';
    modalInfo.style.display = 'none';
    modalLoad.style.display = 'none';
  }

  function openPreview(data: { title: string; description: string; tags: string[]; github: string | null; demo: string | null }) {
    modalTitle.textContent = data.title;

    // Header buttons
    modalGithub.style.display = data.github ? 'inline-flex' : 'none';
    if (data.github) modalGithub.href = data.github;

    modalDemo.style.display = data.demo ? 'inline-flex' : 'none';
    if (data.demo) modalDemo.href = data.demo;

    resetBody();

    if (data.demo) {
      // Show iframe with loading state
      iframeWrap.style.display = 'flex';
      modalLoad.style.display = 'flex';
      modalUrl.textContent = data.demo;
      iframe.src = '';
      setTimeout(() => {
        iframe.src = data.demo!;
        let loaded = false;
        const hide = () => { if (!loaded) { loaded = true; modalLoad.style.display = 'none'; } };
        iframe.onload = hide;
        setTimeout(hide, 9000); // fallback
      }, 80);
    } else if (data.github) {
      // No demo — show project info card
      modalInfo.style.display = 'flex';
      infoTitle.textContent = data.title;
      infoDesc.textContent = data.description;
      infoTags.innerHTML = data.tags.map(t => `<span>${t}</span>`).join('');
      infoLink.href = data.github;
    }

    modal.setAttribute('aria-hidden', 'false');
    modal.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal.classList.remove('open');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    setTimeout(() => { iframe.src = ''; }, 250);
  }

  modalClose.addEventListener('click', closeModal);
  modal.addEventListener('click', e => { if (e.target === modal) closeModal(); });
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

  // Listen for preview button clicks (delegated, works for all cards)
  document.addEventListener('click', e => {
    const btn = (e.target as Element).closest('[data-preview]') as HTMLElement | null;
    if (!btn) return;
    e.preventDefault();
    openPreview({
      title:       btn.dataset.title || '',
      description: btn.dataset.description || '',
      tags:        JSON.parse(btn.dataset.tags || '[]'),
      github:      btn.dataset.github || null,
      demo:        btn.dataset.demo || null,
    });
  });
</script>
